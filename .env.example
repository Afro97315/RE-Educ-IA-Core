# .env.example
# ---------------------------------------------------------------
# MODELE DE VARIABLES D'ENVIRONNEMENT
#
# Copiez ce fichier en ".env" pour votre environnement local :
#   cp .env.example .env
#
# Le fichier .env est dans .gitignore : il ne sera JAMAIS
# envoye sur GitHub (securite des cles secretes).
#
# En production (Render, Railway, Heroku), definissez ces
# variables dans le dashboard de votre plateforme.
# ---------------------------------------------------------------

# Cle secrete Flask : protege les sessions
# Generez une valeur forte : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete

# Port d'ecoute du serveur (injecte automatiquement par Render/Railway)
PORT=10000

# Optionnel : niveau de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
